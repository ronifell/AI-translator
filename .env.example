OPENAI_API_KEY=sk-...
# Optional: OpenAI-compatible endpoint (e.g. Azure, local)
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Retries on transient API errors (429 rate limits, timeouts, 5xx). Raise this
# for very large documents that sustain heavy request load.
# OPENAI_MAX_RETRIES=8
# Max concurrent AI requests across the whole document. Lower this if you keep
# hitting per-minute rate limits on large files.
# AI_MAX_CONCURRENCY=12
